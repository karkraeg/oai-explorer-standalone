# Environment for api.php
# Copy to .env and adjust values locally.

APP_ENV=development
FETCH_TIMEOUT=60
CACHE_TTL=7200
OAI_USER_AGENT=OAI-PMH-Explorer/3.0.2

# Optional. Leave empty for local SQLite fallback.
# Docker Compose sets this to Postgres.
DATABASE_URL=
DATABASE_USER=
DATABASE_PASSWORD=

# Background identifier harvest. Records/XML are never stored by the worker.
HARVEST_DELAY_MS=3000
HARVEST_PAGE_SIZE=100
HARVEST_MAX_SCOPE_ENTRIES=1000000
HARVEST_MAX_INACTIVE_DAYS=90
WORKER_SLEEP_SECONDS=10
